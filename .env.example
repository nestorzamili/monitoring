# Copy to .env before running the stack.
TZ=Asia/Jakarta
ALERT_INSTANCE=vm-prod-01

# Space-separated container names to inspect via Docker.
DOCKER_TARGETS=naoto-be naoto-fe naoto-web naoto-docs
SCRAPE_INTERVAL_SECONDS=30

# Telegram receiver config.
TELEGRAM_BOT_TOKEN=1234567890:replace_me
TELEGRAM_CHAT_ID=-1001234567890
